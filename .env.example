# Neon / async PostgreSQL (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://user:password@ep-example.us-east-2.aws.neon.tech/neondb?ssl=require

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

GOOGLE_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash
# --- RAG: keep these three identical to src/app/core/config.py (PROJECT_* constants) ---
# Embed model id (Google Generative AI embedContent)
EMBEDDING_MODEL=models/gemini-embedding-001
# Gemini output_dimensionality (must equal VECTOR_SIZE)
EMBEDDING_OUTPUT_DIMENSIONALITY=768

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Qdrant dense vector size (must equal EMBEDDING_OUTPUT_DIMENSIONALITY)
VECTOR_SIZE=768
DISTANCE=COSINE
COLLECTION_NAME=rag_collection

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RAG_RETRIEVAL_K=4

# Hyperbrowser (LangChain HyperbrowserLoader — https://docs.langchain.com/oss/python/integrations/document_loaders/hyperbrowser)
HYPERBROWSER_API_KEY=
# Comma-separated URLs to scrape (scrape) or one seed URL for crawl
RAG_INGEST_URLS=
# scrape | crawl (crawl = single URL only)
HYPERBROWSER_OPERATION=scrape

LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=fastapi-rag-agent

# LLM tuning (used by ChatGoogleGenerativeAI)
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2048
