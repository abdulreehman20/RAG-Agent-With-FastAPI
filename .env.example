# Neon / async PostgreSQL (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://user:password@ep-example.us-east-2.aws.neon.tech/neondb?ssl=require

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_documents

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RAG_RETRIEVAL_K=4

LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=fastapi-rag-agent

# LLM tuning (used by ChatGoogleGenerativeAI)
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2048
